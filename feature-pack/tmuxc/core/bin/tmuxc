#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
tmuxc - tmux session launcher for Claude, Codex, and OMX

Usage:
  tmuxc open <path> [--name NAME] [--agent claude|codex|omx] [--role worker|analysis|orchestrator|implementer|planner] [--model ID] [--effort E] [--like SESSION] [--prompt TEXT] [--dry-run]
  tmuxc wt <worktree-path> [same options as open]
  tmuxc list
  tmuxc attach <name>
  tmuxc send <name> <message>
  tmuxc ask <name> [lines]
  tmuxc model <name>              # м„ём…ҳмқҳ лқјмқҙлёҢ --model/--effort мЎ°нҡҢ (мҰқлҘҳ лӘЁлҚё мҠ№кі„мҡ©)
  tmuxc msg <name> <message>
  tmuxc kill <name>
  tmuxc clean
  tmuxc restore [--since HOURS] [--agent claude|codex|all] [--select 1,3,5|all|claude|codex] [--baton] [--loose] [--go]

Defaults:
  agent: ${TMUXC_AGENT:-claude}
  role:  worker
EOF
}

die() {
  printf 'tmuxc: %s\n' "$*" >&2
  exit 1
}

sanitize_name() {
  local raw="$1"
  raw="${raw// /-}"
  raw="${raw//:/-}"
  raw="${raw//./-}"
  printf '%s' "$raw" | LC_ALL=C tr -cd 'A-Za-z0-9_#-'
}

repo_root_for() {
  local path="$1"
  local root
  root="$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$root" ]]; then
    printf '%s\n' "$root"
  else
    cd "$path" && pwd
  fi
}

role_alias() {
  case "${1:-worker}" in
    worker|analysis|analyze|log|logs|doc|docs|review|verify|verifier|check|bts|architect-check|architecture-check) printf 'ccs' ;;
    orchestrator|orch|implementer|implement|implementation|planner|plan|planning|designer|architect|strategy|strategist) printf 'ccd' ;;
    crew|plugin) printf '__crew__' ;;  # zshrc alias л¬ҙмқҳмЎҙ вҖ” resolve_claude_cmdк°Җ м§Ғм ‘ н•©м„ұ (2026-07-13 мқҙмҠҲ: нҒ¬лЈЁк°Җ ccd=opus-4-8[1m] highлЎң мҳӨнҸҙл°ұ)
    *) die "unknown role: $1" ;;
  esac
}

# crew/plugin role кі м • мҠӨнҺҷ вҖ” claude н”Ңлҹ¬к·ёмқё нҒ¬лЈЁ(agent-cliВ·omoВ·gstack л“ұ) л“ңлқјмқҙлІ„ мһҗмӢқ м„ём…ҳ.
# fable-team crew-support.md кі„м•Ҫ(claude-sonnet-4-6 + medium)кіј м •н•©. --model/--effort лӘ…мӢңк°Җ н•ӯмғҒ мҡ°м„ .
CREW_MODEL="claude-sonnet-4-6"
CREW_EFFORT="medium"

zsh_alias_body() {
  local alias_name="$1"
  local out
  out="$(zsh -ic "type $alias_name" 2>/dev/null || true)"
  if [[ "$out" == *" is an alias for "* ]]; then
    printf '%s\n' "${out#* is an alias for }"
  elif command -v "$alias_name" >/dev/null 2>&1; then
    printf '%s\n' "$alias_name"
  else
    return 1
  fi
}

resolve_zsh_alias_chain() {
  local alias_name="$1"
  local body
  local depth=0
  local current="$alias_name"
  while [[ "$depth" -lt 6 ]]; do
    body="$(zsh_alias_body "$current" || true)"
    [[ -n "$body" ]] || return 1
    if [[ "$body" =~ ^[A-Za-z_][A-Za-z0-9_-]*$ ]]; then
      current="$body"
      depth=$((depth + 1))
      continue
    fi
    printf '%s\n' "$body"
    return 0
  done
  die "alias chain too deep: $alias_name"
}

resolve_claude_cmd() {
  local name="$1"
  local role="$2"
  local model="${3:-}"
  local effort="${4:-}"
  # лӘ…мӢңм Ғ --model мҳӨлІ„лқјмқҙл“ң: role_alias/zsh alias мІҙмқёмқ„ мҡ°нҡҢн•ҳкі  headroom кё°лҸҷ
  # м»Өл§Ёл“ңлҘј м§Ғм ‘ н•©м„ұн•ңлӢӨ (ft-tmux-spawn.sh raw_launch_fallbackкіј лҸҷмқј л°©мӢқ вҖ” л°©мӢқ л¶„кё° кёҲм§Җ).
  # лӘЁлҚё л¬ёмһҗм—ҙмқҳ [1m] м°Ҫ м„ нғқмһҗлҠ” нҒ°л”°мҳҙн‘ңлЎң ліҙмЎҙн•ңлӢӨ(cc/ccs1m aliasмҷҖ лҸҷмқј мқёмҡ© вҶ’ кёҖлЎӯ л°©м§Җ).
  if [[ -n "$model" ]]; then
    local cmd
    cmd="$HOME/.headroom/claude-hr.sh --dangerously-skip-permissions --model \"$model\""
    [[ -n "$effort" ]] && cmd="$cmd --effort $effort"
    printf '%s --name %q --remote-control %q' "$cmd" "$name" "$name"
    return 0
  fi
  local alias_name
  alias_name="$(role_alias "$role")"
  # crew/plugin role: alias мІҙмқё лҢҖмӢ  кі м • мҠӨнҺҷ м§Ғм ‘ н•©м„ұ (--model мҳӨлІ„лқјмқҙл“ң л¶„кё°мҷҖ лҸҷмқј л°©мӢқ)
  if [[ "$alias_name" == "__crew__" ]]; then
    local cmd
    cmd="$HOME/.headroom/claude-hr.sh --dangerously-skip-permissions --model \"$CREW_MODEL\" --effort ${effort:-$CREW_EFFORT}"
    printf '%s --name %q --remote-control %q' "$cmd" "$name" "$name"
    return 0
  fi
  local body
  body="$(resolve_zsh_alias_chain "$alias_name" || true)"
  if [[ -z "$body" ]]; then
    die "missing Claude alias for role '$role': $alias_name"
  fi
  printf '%s --name %q --remote-control %q' "$body" "$name" "$name"
}

resolve_codex_cmd() {
  local agent="$1"
  local role="$2"
  case "$agent" in
    codex)
      case "$role" in
        worker|crew|plugin) printf 'codex --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="medium"' ;;
        orchestrator|orch|verify|verifier|designer|architect|strategy|strategist) printf 'codex --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="high"' ;;
        *) die "unknown role: $role" ;;
      esac
      ;;
    omx)
      case "$role" in
        worker) printf 'omx --madmax' ;;
        orchestrator|orch|verify|verifier|designer|architect|strategy|strategist) printf 'omx --madmax --high' ;;
        *) die "unknown role: $role" ;;
      esac
      ;;
    *) die "unsupported codex agent: $agent" ;;
  esac
}

agent_cmd() {
  local agent="$1"
  local name="$2"
  local role="$3"
  local model="${4:-}"
  local effort="${5:-}"
  case "$agent" in
    claude) resolve_claude_cmd "$name" "$role" "$model" "$effort" ;;
    codex|omx) resolve_codex_cmd "$agent" "$role" ;;
    *) die "unknown agent: $agent" ;;
  esac
}

# м„ём…ҳмқҳ лқјмқҙлёҢ claude н”„лЎңм„ёмҠӨ argvм—җм„ң --model/--effort лҘј нҡҢмҲҳн•ңлӢӨ.
# нҠёлһңмҠӨнҒ¬лҰҪнҠёмқҳ "model" н•„л“ңлҠ” [1m] м°Ҫ м„ нғқмһҗВ·effortлҘј лӢҙм§Җ м•ҠмңјлҜҖлЎң(мӢӨмёЎ нҷ•мқё),
# н”„лЎңм„ёмҠӨ argvк°Җ мң мқјн•ң authoritative мҶҢмҠӨлӢӨ. лқјмқҙлёҢ м„ём…ҳм—җл§Ң мң нҡЁ.
# м¶ңл Ҙ: "model=<id>" (+ мһҲмңјл©ҙ "effort=<e>"), нҡҢмҲҳ мӢӨнҢЁ мӢң л№„-0 мў…лЈҢ.
session_live_launch() {
  local sess="$1"
  tmux has-session -t "$sess" 2>/dev/null || return 1
  local ppid
  ppid="$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1)"
  [[ -n "$ppid" ]] || return 1
  local pids pid cmd model="" effort=""
  pids="$ppid $(pgrep -P "$ppid" 2>/dev/null || true) $(pgrep -g "$ppid" 2>/dev/null || true)"
  for pid in $pids; do
    cmd="$(ps -o command= -p "$pid" 2>/dev/null || true)"
    [[ "$cmd" == *--model* ]] || continue
    local -a toks=()
    read -ra toks <<< "$cmd"
    local tok prev=""
    for tok in "${toks[@]}"; do
      [[ "$prev" == "--model" ]] && model="$tok"
      [[ "$prev" == "--effort" ]] && effort="$tok"
      prev="$tok"
    done
    [[ -n "$model" ]] && break
  done
  [[ -n "$model" ]] || return 1
  printf 'model=%s\n' "$model"
  [[ -n "$effort" ]] && printf 'effort=%s\n' "$effort"
  return 0
}

inject_message() {
  local session="$1"
  local message="$2"
  tmux send-keys -t "$session" -l "$message"
  sleep 0.3
  tmux send-keys -t "$session" Enter
}

cmd_open() {
  local path=""
  local name=""
  local agent="${TMUXC_AGENT:-claude}"
  local role="${TMUXC_ROLE:-worker}"
  local prompt=""
  local dry_run=0
  local model=""
  local effort=""
  local like=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="${2:-}"; shift 2 ;;
      --agent) agent="${2:-}"; shift 2 ;;
      --role) role="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      --effort) effort="${2:-}"; shift 2 ;;
      --like) like="${2:-}"; shift 2 ;;
      --prompt) prompt="${2:-}"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --help|-h) usage; exit 0 ;;
      --*) die "unknown option for open: $1" ;;
      *)
        if [[ -z "$path" ]]; then
          path="$1"; shift
        else
          die "unexpected argument: $1"
        fi
        ;;
    esac
  done

  [[ -n "$path" ]] || die "open requires <path>"
  [[ -d "$path" ]] || die "path does not exist: $path"

  local root
  root="$(repo_root_for "$path")"
  if [[ -z "$name" ]]; then
    name="$(basename "$root")"
  fi
  name="$(sanitize_name "$name")"
  [[ -n "$name" ]] || die "empty session name after sanitize"

  # --model/--effort/--like мҳӨлІ„лқјмқҙл“ңлҠ” claude м „мҡ© (codex/omxлҠ” roleвҶ’effort кі м •)
  if [[ -n "$model" || -n "$effort" || -n "$like" ]] && [[ "$agent" != "claude" ]]; then
    die "--model/--effort/--like лҠ” --agent claude м—җм„ңл§Ң мӮ¬мҡ© (agent=$agent)"
  fi
  # --like SESSION: м§Җм •н•ң лқјмқҙлёҢ м„ём…ҳмқҳ лӘЁлҚё/effortлҘј мғҒмҶҚ (лӘ…мӢң --model/--effort к°Җ мҡ°м„ )
  if [[ -n "$like" ]]; then
    local like_out
    like_out="$(session_live_launch "$like" || true)"
    [[ -n "$like_out" ]] || die "--like: м„ём…ҳ '$like' мқҳ лқјмқҙлёҢ лӘЁлҚё мЎ°нҡҢ мӢӨнҢЁ (лҜёкё°лҸҷ/claude м•„лӢҳ)"
    [[ -n "$model" ]]  || model="$(printf '%s\n' "$like_out" | sed -n 's/^model=//p' | head -1)"
    [[ -n "$effort" ]] || effort="$(printf '%s\n' "$like_out" | sed -n 's/^effort=//p' | head -1)"
  fi

  local run_cmd
  run_cmd="$(agent_cmd "$agent" "$name" "$role" "$model" "$effort")"

  if [[ "$dry_run" -eq 1 ]]; then
    printf 'session=%s\nroot=%s\nagent=%s\nrole=%s\ncommand=%s\n' "$name" "$root" "$agent" "$role" "$run_cmd"
    return 0
  fi

  tmux has-session -t "$name" 2>/dev/null && die "session already exists: $name"
  tmux new-session -d -s "$name" -c "$root"
  inject_message "$name" "$run_cmd"
  sleep 4

  local guide
  if [[ "$agent" == "claude" ]]; then
    guide="[$(tmux display-message -p '#S' 2>/dev/null || printf 'orch')вҶ’$name] нҶөмӢ  н‘ңмӨҖ: ~/.claude/skills/tmuxc/COMM-GUIDE.md лҘј м§ҖкёҲ Readн•ҳкі  к·ёлҢҖлЎң л”°лҘј кІғ. л„Ҳмқҳ м„ём…ҳлӘ…(me)=$name. м„ём…ҳк°„ л©”мӢңм§ҖлҠ” кІҖмҰқ мҶЎмӢ  н”„лЎңнҶ мҪң мӨҖмҲҳ."
  else
    guide="[$(tmux display-message -p '#S' 2>/dev/null || printf 'orch')вҶ’$name] tmuxc Codex м„ём…ҳ. нҶөмӢ  н‘ңмӨҖ: ~/.claude/skills/tmuxc/COMM-GUIDE.md лҘј м°ёкі н•ҳлҗҳ, Codexм—җлҠ” --remote-controlмқҙ м—ҶмңјлҜҖлЎң tmux verified-send/capture-pane л°©мӢқмңјлЎң ліҙкі н•  кІғ. л„Ҳмқҳ м„ём…ҳлӘ…(me)=$name."
  fi
  inject_message "$name" "$guide"
  if [[ -n "$prompt" ]]; then
    sleep 0.8
    inject_message "$name" "$prompt"
  fi

  printf 'tmuxc session created\nsession=%s\nroot=%s\nagent=%s\nrole=%s\nattach=tmux attach -t %q\n' "$name" "$root" "$agent" "$role" "$name"
}

cmd_list() {
  tmux list-sessions -F '#S	#{session_path}	#{session_attached}' 2>/dev/null || return 0
}

cmd_ask() {
  local name="${1:-}"
  local lines="${2:-40}"
  [[ -n "$name" ]] || die "ask requires <name>"
  tmux has-session -t "$name" 2>/dev/null || die "session not found: $name"
  tmux capture-pane -t "$name" -p | tail -n "$lines"
}

cmd_send() {
  local name="${1:-}"
  shift || true
  [[ -n "$name" ]] || die "send requires <name>"
  [[ $# -gt 0 ]] || die "send requires <message>"
  tmux has-session -t "$name" 2>/dev/null || die "session not found: $name"
  inject_message "$name" "$*"
  sleep 1
  if tmux capture-pane -t "$name" -p | tail -80 | grep -qF "$*"; then
    printf 'delivered=%s\n' "$name"
  else
    printf 'sent=%s verification=not-visible-yet\n' "$name"
  fi
}

cmd_clean() {
  local session command
  while IFS=$'\t' read -r session command; do
    if [[ "$command" == "zsh" || "$command" == "bash" || "$command" == "fish" ]]; then
      printf '%s\n' "$session"
    fi
  done < <(tmux list-panes -a -F '#S	#{pane_current_command}' 2>/dev/null || true)
}

# ---------- UC11: tmux м„ңлІ„ мӮ¬л§қ ліөмӣҗ (restore) ----------

restore_scan_py() {
  local self
  self="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
  printf '%s/../libexec/tmuxc-restore-scan.py' "$(dirname "$self")"
}

# н–ү л°°м—ҙ (мҠӨмәҗл„Ҳ TSVмҷҖ 1:1)
R_AGENT=() R_NAME=() R_CWD=() R_MODEL=() R_ROUTE=() R_SID=() R_TS=() R_STATUS=() R_SUMMARY=()

restore_load_rows() {
  local since="$1" agent_filter="$2" loose="$3"
  local scan_py extra=()
  scan_py="$(restore_scan_py)"
  [[ -f "$scan_py" ]] || die "scan engine not found: $scan_py"
  [[ "$loose" -eq 1 ]] && extra+=(--loose)
  # кө¬л¶„мһҗ 0x1f: нғӯмқҖ IFS whitespaceлқј л№Ҳ мӨ‘к°„ н•„л“ң(cwd="")к°Җ collapseлҗҳм–ҙ н•„л“ңк°Җ л°ҖлҰј
  local a n c m r s t st sum
  while IFS=$'\x1f' read -r a n c m r s t st sum; do
    [[ -n "$a" ]] || continue
    R_AGENT+=("$a"); R_NAME+=("$n"); R_CWD+=("$c"); R_MODEL+=("$m")
    R_ROUTE+=("$r"); R_SID+=("$s"); R_TS+=("$t"); R_STATUS+=("$st"); R_SUMMARY+=("$sum")
  done < <(python3 "$scan_py" --since "$since" --agent "$agent_filter" "${extra[@]+"${extra[@]}"}")
}

restore_cmd_for() {
  local i="$1" baton="$2"
  local agent="${R_AGENT[$i]}" name="${R_NAME[$i]}" route="${R_ROUTE[$i]}" sid="${R_SID[$i]}"
  if [[ "$agent" == "codex" ]]; then
    printf 'codex resume %s --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="high"' "$sid"
    return 0
  fi
  local body
  body="$(resolve_zsh_alias_chain "$route" || true)"
  [[ -n "$body" ]] || return 1
  if [[ "$baton" -eq 1 ]]; then
    printf '%s --name %q --remote-control %q' "$body" "$name" "$name"
  else
    printf '%s --resume %s --name %q --remote-control %q' "$body" "$sid" "$name" "$name"
  fi
}

restore_print_table() {
  local i
  printf '\nліөкө¬ нӣ„ліҙ (%dк°ң вҖ” мөңмӢ мҲң)\n' "${#R_NAME[@]}"
  printf '%-3s %-7s %-24s %-20s %-5s %-7s %s\n' '#' agent м„ём…ҳлӘ… лӘЁлҚё route мғҒнғң мҡ”м•Ҫ
  for i in "${!R_NAME[@]}"; do
    printf '%-3s %-7s %-24s %-20s %-5s %-7s %s\n' \
      "$((i + 1))" "${R_AGENT[$i]}" "${R_NAME[$i]}" "${R_MODEL[$i]}" "${R_ROUTE[$i]}" "${R_STATUS[$i]}" "${R_SUMMARY[$i]}"
    printf '    cwd=%s\n' "${R_CWD[$i]}"
    printf '    cmd=%s\n' "$(restore_cmd_for "$i" 0 || printf '(alias %s лҜён•ҙм„қ вҖ” ліөкө¬ л¶Ҳк°Җ)' "${R_ROUTE[$i]}")"
  done
}

restore_expand_select() {
  local spec="$1" i
  case "$spec" in
    all)    for i in "${!R_NAME[@]}"; do printf '%s\n' "$i"; done ;;
    claude|codex)
      for i in "${!R_NAME[@]}"; do [[ "${R_AGENT[$i]}" == "$spec" ]] && printf '%s\n' "$i"; done ;;
    *)
      local tok
      IFS=',' read -ra toks <<< "$spec"
      for tok in "${toks[@]}"; do
        tok="${tok// /}"
        [[ "$tok" =~ ^[0-9]+$ ]] || die "мһҳлӘ»лҗң м„ нғқ: '$tok' (мҲ«мһҗ, all, claude, codexл§Ң н—Ҳмҡ©)"
        [[ "$tok" -ge 1 && "$tok" -le "${#R_NAME[@]}" ]] || die "м„ нғқ лІ”мң„ л°–: $tok (1-${#R_NAME[@]})"
        printf '%s\n' "$((tok - 1))"
      done
      ;;
  esac
}

restore_wait_ready() {
  local name="$1" agent="$2" try pane child
  for try in 1 2 3 4 5 6 7 8; do
    sleep 3
    if [[ "$agent" == "claude" ]]; then
      # resume м„ём…ҳмқҖ ctx:0%к°Җ м•„лӢҳ вҖ” statuslineмқҳ ctx: м¶ңнҳ„ = л¶ҖнҢ… мҷ„лЈҢ
      tmux capture-pane -t "$name" -p 2>/dev/null | grep -q 'ctx:' && return 0
    else
      pane="$(tmux list-panes -t "$name" -F '#{pane_pid}' 2>/dev/null | head -1)"
      child="$(pgrep -P "${pane:-0}" 2>/dev/null | head -1 || true)"
      [[ -n "$child" ]] && [[ "$try" -ge 3 ]] && return 0
    fi
  done
  return 1
}

restore_one() {
  local i="$1" baton="$2"
  local agent="${R_AGENT[$i]}" name="${R_NAME[$i]}" cwd="${R_CWD[$i]}" sid="${R_SID[$i]}"
  if [[ "${R_STATUS[$i]}" != "ok" ]]; then
    printf '  вҸӯ  %s: мғҒнғң=%s вҖ” мҠӨнӮө\n' "$name" "${R_STATUS[$i]}"
    return 0
  fi
  if tmux has-session -t "$name" 2>/dev/null; then
    printf '  вҸӯ  %s: лҸҷлӘ… tmux м„ём…ҳ мқҙлҜё мЎҙмһ¬ вҖ” мҠӨнӮө\n' "$name"
    return 0
  fi
  local run_cmd
  run_cmd="$(restore_cmd_for "$i" "$baton" || true)"
  if [[ -z "$run_cmd" ]]; then
    printf '  вқҢ %s: alias %s н•ҙм„қ мӢӨнҢЁ вҖ” мҠӨнӮө (zshrc нҷ•мқё)\n' "$name" "${R_ROUTE[$i]}"
    return 0
  fi
  tmux new-session -d -s "$name" -c "$cwd"
  inject_message "$name" "$run_cmd"
  if restore_wait_ready "$name" "$agent"; then
    if [[ "$agent" == "claude" ]]; then
      if [[ "$baton" -eq 1 ]]; then
        inject_message "$name" "/baton:resume"
        sleep 1
      fi
      inject_message "$name" "[restoreвҶ’$name] tmux м„ңлІ„ мӮ¬л§қ нӣ„ tmuxc restoreлЎң ліөмӣҗлҗң м„ём…ҳмқҙлӢӨ. нҶөмӢ  н‘ңмӨҖ: ~/.claude/skills/tmuxc/COMM-GUIDE.md лҘј Readн•ҳкі  мӨҖмҲҳ. л„Ҳмқҳ м„ём…ҳлӘ…(me)=$name. м§Ғм „ мһ‘м—… м»Ён…ҚмҠӨнҠёлҘј нҷ•мқён•ҳкі  мқҙм–ҙк°Җлқј."
    fi
    printf '  вң… %s (%s) ліөмӣҗ мҷ„лЈҢ вҖ” attach: tmux attach -t %q\n' "$name" "$agent" "$name"
  else
    printf '  вҡ пёҸ  %s: кё°лҸҷ нҷ•мқё мӢӨнҢЁ(24мҙҲ) вҖ” мҲҳлҸҷ нҷ•мқё н•„мҡ”: tmux attach -t %q\n' "$name" "$name"
  fi
}

cmd_restore() {
  local since=24 agent_filter="all" select_spec="" baton=0 go=0 loose=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since) since="${2:-}"; shift 2 ;;
      --agent) agent_filter="${2:-}"; shift 2 ;;
      --select) select_spec="${2:-}"; shift 2 ;;
      --baton) baton=1; shift ;;
      --loose) loose=1; shift ;;
      --go) go=1; shift ;;
      --help|-h) usage; exit 0 ;;
      *) die "unknown option for restore: $1" ;;
    esac
  done
  case "$agent_filter" in claude|codex|all) ;; *) die "--agent must be claude|codex|all" ;; esac

  if tmux list-sessions >/dev/null 2>&1; then
    printf 'вҡ пёҸ  tmux м„ңлІ„к°Җ мӮҙм•„мһҲмҠөлӢҲлӢӨ (м„ём…ҳ %sк°ң). м„ңлІ„ мӮ¬л§қ(UC11)мқҙ м•„лӢҲлқј л””мҠӨм»Өл„ҘнҠё(UC8)мқј мҲҳ мһҲмқҢ вҖ” cmuxл©ҙ tmuxc recover кІҖнҶ .\n' \
      "$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')"
  fi

  restore_load_rows "$since" "$agent_filter" "$loose"
  if [[ "${#R_NAME[@]}" -eq 0 ]]; then
    printf 'ліөкө¬ нӣ„ліҙ м—ҶмқҢ (мөңк·ј %sмӢңк°„, agent=%s). --since лҘј лҠҳл Өліҙм„ёмҡ”.\n' "$since" "$agent_filter"
    case "$agent_filter" in
      codex|all)
        printf '  нһҢнҠё: codex лҢҖнҷ”нҳ•(cli) м„ём…ҳмқҖ thread_name м—Ҷмқҙ мқөлӘ…мңјлЎң кё°лЎқлҗҳлҠ” кІҪмҡ°к°Җ мһҲм–ҙ, мөңк·ј м„ём…ҳмқҙ м—Ҷмңјл©ҙ --since 168 мІҳлҹј лҠҳл Өм„ң лӢӨмӢң мӢңлҸ„н•ҙліҙм„ёмҡ”.\n'
        ;;
    esac
    return 0
  fi
  restore_print_table

  if [[ -z "$select_spec" ]]; then
    if [[ "$go" -eq 1 ]]; then
      die "--go лҠ” --select мҷҖ н•Ёк»ҳ мӮ¬мҡ©н•ҳм„ёмҡ” (мҳҲ: --select all --go)"
    fi
    if [[ -t 0 ]]; then
      printf '\nліөкө¬н•  м„ём…ҳ м„ нғқ (мҳҲ: 1,3,5 / all / claude / codex / q=мў…лЈҢ): '
      read -r select_spec
      [[ -n "$select_spec" && "$select_spec" != "q" ]] || { printf 'м·ЁмҶҢлҗЁ.\n'; return 0; }
      go=1
    else
      printf '\n(plan лӘЁл“ң вҖ” мӢӨн–үн•ҳл Өл©ҙ: tmuxc restore --select all --go)\n'
      return 0
    fi
  fi

  local indices=()
  while IFS= read -r i; do indices+=("$i"); done < <(restore_expand_select "$select_spec")
  [[ "${#indices[@]}" -gt 0 ]] || { printf 'м„ нғқлҗң м„ём…ҳ м—ҶмқҢ.\n'; return 0; }

  if [[ "$go" -ne 1 ]]; then
    printf '\n(plan лӘЁл“ң вҖ” м„ нғқ %dк°ң. мӢӨн–үн•ҳл Өл©ҙ --go м¶”к°Җ)\n' "${#indices[@]}"
    return 0
  fi

  printf '\nв–¶ %dк°ң м„ём…ҳ ліөмӣҗ мӢңмһ‘\n' "${#indices[@]}"
  local i
  for i in "${indices[@]}"; do
    restore_one "$i" "$baton"
  done
  printf 'мҷ„лЈҢ. tmuxc list лЎң нҷ•мқён•ҳм„ёмҡ”.\n'
}

main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] || { usage; exit 1; }
  shift || true
  case "$cmd" in
    open|wt) cmd_open "$@" ;;
    list) cmd_list ;;
    attach)
      [[ -n "${1:-}" ]] || die "attach requires <name>"
      tmux attach -t "$1"
      ;;
    send) cmd_send "$@" ;;
    ask) cmd_ask "$@" ;;
    model)
      [[ -n "${1:-}" ]] || die "model requires <name>"
      session_live_launch "$1" || die "session not live or model not found: $1"
      ;;
    msg)
      [[ -n "${1:-}" ]] || die "msg requires <name> <message>"
      local name="$1"
      shift
      cmd_send "$name" "$@"
      sleep 2
      cmd_ask "$name" 30
      ;;
    kill)
      [[ -n "${1:-}" ]] || die "kill requires <name>"
      tmux kill-session -t "$1"
      ;;
    clean) cmd_clean ;;
    restore) cmd_restore "$@" ;;
    help|--help|-h) usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
