#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
tmuxc - tmux session launcher for Claude, Codex, and OMX

Usage:
  tmuxc open <path> [--name NAME] [--agent claude|codex|omx] [--role worker|analysis|orchestrator|implementer|planner] [--model ID] [--effort E] [--like SESSION] [--prompt TEXT] [--dry-run]
  tmuxc wt <worktree-path> [same options as open]
  tmuxc list
  tmuxc attach <name>
  tmuxc send <name> <message>
  tmuxc ask <name> [lines]
  tmuxc model <name>              # 세션의 라이브 --model/--effort 조회 (증류 모델 승계용)
  tmuxc msg <name> <message>
  tmuxc kill <name>
  tmuxc clean
  tmuxc restore [--since HOURS] [--agent claude|codex|all] [--select 1,3,5|all|claude|codex] [--baton] [--loose] [--go]

Defaults:
  agent: ${TMUXC_AGENT:-claude}
  role:  worker
EOF
}

die() {
  printf 'tmuxc: %s\n' "$*" >&2
  exit 1
}

sanitize_name() {
  local raw="$1"
  raw="${raw// /-}"
  raw="${raw//:/-}"
  raw="${raw//./-}"
  printf '%s' "$raw" | LC_ALL=C tr -cd 'A-Za-z0-9_#-'
}

repo_root_for() {
  local path="$1"
  local root
  root="$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$root" ]]; then
    printf '%s\n' "$root"
  else
    cd "$path" && pwd
  fi
}

role_alias() {
  case "${1:-worker}" in
    worker|analysis|analyze|log|logs|doc|docs|review|verify|verifier|check|bts|architect-check|architecture-check) printf 'ccs' ;;
    orchestrator|orch|implementer|implement|implementation|planner|plan|planning|designer|architect|strategy|strategist) printf 'ccd' ;;
    crew|plugin) printf '__crew__' ;;  # zshrc alias 무의존 — resolve_claude_cmd가 직접 합성 (2026-07-13 이슈: 크루가 ccd=opus-4-8[1m] high로 오폴백)
    *) die "unknown role: $1" ;;
  esac
}

# crew/plugin role 고정 스펙 — claude 플러그인 크루(agent-cli·omo·gstack 등) 드라이버 자식 세션.
# fable-team crew-support.md 계약(claude-sonnet-4-6 + medium)과 정합. --model/--effort 명시가 항상 우선.
CREW_MODEL="claude-sonnet-4-6"
CREW_EFFORT="medium"

zsh_alias_body() {
  local alias_name="$1"
  local out
  out="$(zsh -ic "type $alias_name" 2>/dev/null || true)"
  if [[ "$out" == *" is an alias for "* ]]; then
    printf '%s\n' "${out#* is an alias for }"
  elif command -v "$alias_name" >/dev/null 2>&1; then
    printf '%s\n' "$alias_name"
  else
    return 1
  fi
}

resolve_zsh_alias_chain() {
  local alias_name="$1"
  local body
  local depth=0
  local current="$alias_name"
  while [[ "$depth" -lt 6 ]]; do
    body="$(zsh_alias_body "$current" || true)"
    [[ -n "$body" ]] || return 1
    if [[ "$body" =~ ^[A-Za-z_][A-Za-z0-9_-]*$ ]]; then
      current="$body"
      depth=$((depth + 1))
      continue
    fi
    printf '%s\n' "$body"
    return 0
  done
  die "alias chain too deep: $alias_name"
}

resolve_claude_cmd() {
  local name="$1"
  local role="$2"
  local model="${3:-}"
  local effort="${4:-}"
  # 명시적 --model 오버라이드: role_alias/zsh alias 체인을 우회하고 headroom 기동
  # 커맨드를 직접 합성한다 (ft-tmux-spawn.sh raw_launch_fallback과 동일 방식 — 방식 분기 금지).
  # 모델 문자열의 [1m] 창 선택자는 큰따옴표로 보존한다(cc/ccs1m alias와 동일 인용 → 글롭 방지).
  if [[ -n "$model" ]]; then
    local cmd
    cmd="$HOME/.headroom/claude-hr.sh --dangerously-skip-permissions --model \"$model\""
    [[ -n "$effort" ]] && cmd="$cmd --effort $effort"
    printf '%s --name %q --remote-control %q' "$cmd" "$name" "$name"
    return 0
  fi
  local alias_name
  alias_name="$(role_alias "$role")"
  # crew/plugin role: alias 체인 대신 고정 스펙 직접 합성 (--model 오버라이드 분기와 동일 방식)
  if [[ "$alias_name" == "__crew__" ]]; then
    local cmd
    cmd="$HOME/.headroom/claude-hr.sh --dangerously-skip-permissions --model \"$CREW_MODEL\" --effort ${effort:-$CREW_EFFORT}"
    printf '%s --name %q --remote-control %q' "$cmd" "$name" "$name"
    return 0
  fi
  local body
  body="$(resolve_zsh_alias_chain "$alias_name" || true)"
  if [[ -z "$body" ]]; then
    die "missing Claude alias for role '$role': $alias_name"
  fi
  printf '%s --name %q --remote-control %q' "$body" "$name" "$name"
}

resolve_codex_cmd() {
  local agent="$1"
  local role="$2"
  case "$agent" in
    codex)
      case "$role" in
        worker|crew|plugin) printf 'codex --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="medium"' ;;
        orchestrator|orch|verify|verifier|designer|architect|strategy|strategist) printf 'codex --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="high"' ;;
        *) die "unknown role: $role" ;;
      esac
      ;;
    omx)
      case "$role" in
        worker) printf 'omx --madmax' ;;
        orchestrator|orch|verify|verifier|designer|architect|strategy|strategist) printf 'omx --madmax --high' ;;
        *) die "unknown role: $role" ;;
      esac
      ;;
    *) die "unsupported codex agent: $agent" ;;
  esac
}

agent_cmd() {
  local agent="$1"
  local name="$2"
  local role="$3"
  local model="${4:-}"
  local effort="${5:-}"
  case "$agent" in
    claude) resolve_claude_cmd "$name" "$role" "$model" "$effort" ;;
    codex|omx) resolve_codex_cmd "$agent" "$role" ;;
    *) die "unknown agent: $agent" ;;
  esac
}

# 세션의 라이브 claude 프로세스 argv에서 --model/--effort 를 회수한다.
# 트랜스크립트의 "model" 필드는 [1m] 창 선택자·effort를 담지 않으므로(실측 확인),
# 프로세스 argv가 유일한 authoritative 소스다. 라이브 세션에만 유효.
# 출력: "model=<id>" (+ 있으면 "effort=<e>"), 회수 실패 시 비-0 종료.
session_live_launch() {
  local sess="$1"
  tmux has-session -t "$sess" 2>/dev/null || return 1
  local ppid
  ppid="$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1)"
  [[ -n "$ppid" ]] || return 1
  local pids pid cmd model="" effort=""
  pids="$ppid $(pgrep -P "$ppid" 2>/dev/null || true) $(pgrep -g "$ppid" 2>/dev/null || true)"
  for pid in $pids; do
    cmd="$(ps -o command= -p "$pid" 2>/dev/null || true)"
    [[ "$cmd" == *--model* ]] || continue
    local -a toks=()
    read -ra toks <<< "$cmd"
    local tok prev=""
    for tok in "${toks[@]}"; do
      [[ "$prev" == "--model" ]] && model="$tok"
      [[ "$prev" == "--effort" ]] && effort="$tok"
      prev="$tok"
    done
    [[ -n "$model" ]] && break
  done
  [[ -n "$model" ]] || return 1
  printf 'model=%s\n' "$model"
  [[ -n "$effort" ]] && printf 'effort=%s\n' "$effort"
  return 0
}

inject_message() {
  local session="$1"
  local message="$2"
  tmux send-keys -t "$session" -l "$message"
  sleep 0.3
  tmux send-keys -t "$session" Enter
}

cmd_open() {
  local path=""
  local name=""
  local agent="${TMUXC_AGENT:-claude}"
  local role="${TMUXC_ROLE:-worker}"
  local prompt=""
  local dry_run=0
  local model=""
  local effort=""
  local like=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="${2:-}"; shift 2 ;;
      --agent) agent="${2:-}"; shift 2 ;;
      --role) role="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      --effort) effort="${2:-}"; shift 2 ;;
      --like) like="${2:-}"; shift 2 ;;
      --prompt) prompt="${2:-}"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --help|-h) usage; exit 0 ;;
      --*) die "unknown option for open: $1" ;;
      *)
        if [[ -z "$path" ]]; then
          path="$1"; shift
        else
          die "unexpected argument: $1"
        fi
        ;;
    esac
  done

  [[ -n "$path" ]] || die "open requires <path>"
  [[ -d "$path" ]] || die "path does not exist: $path"

  local root
  root="$(repo_root_for "$path")"
  if [[ -z "$name" ]]; then
    name="$(basename "$root")"
  fi
  name="$(sanitize_name "$name")"
  [[ -n "$name" ]] || die "empty session name after sanitize"

  # --model/--effort/--like 오버라이드는 claude 전용 (codex/omx는 role→effort 고정)
  if [[ -n "$model" || -n "$effort" || -n "$like" ]] && [[ "$agent" != "claude" ]]; then
    die "--model/--effort/--like 는 --agent claude 에서만 사용 (agent=$agent)"
  fi
  # --like SESSION: 지정한 라이브 세션의 모델/effort를 상속 (명시 --model/--effort 가 우선)
  if [[ -n "$like" ]]; then
    local like_out
    like_out="$(session_live_launch "$like" || true)"
    [[ -n "$like_out" ]] || die "--like: 세션 '$like' 의 라이브 모델 조회 실패 (미기동/claude 아님)"
    [[ -n "$model" ]]  || model="$(printf '%s\n' "$like_out" | sed -n 's/^model=//p' | head -1)"
    [[ -n "$effort" ]] || effort="$(printf '%s\n' "$like_out" | sed -n 's/^effort=//p' | head -1)"
  fi

  local run_cmd
  run_cmd="$(agent_cmd "$agent" "$name" "$role" "$model" "$effort")"

  if [[ "$dry_run" -eq 1 ]]; then
    printf 'session=%s\nroot=%s\nagent=%s\nrole=%s\ncommand=%s\n' "$name" "$root" "$agent" "$role" "$run_cmd"
    return 0
  fi

  tmux has-session -t "$name" 2>/dev/null && die "session already exists: $name"
  tmux new-session -d -s "$name" -c "$root"
  inject_message "$name" "$run_cmd"
  sleep 4

  local guide
  if [[ "$agent" == "claude" ]]; then
    guide="[$(tmux display-message -p '#S' 2>/dev/null || printf 'orch')→$name] 통신 표준: ~/.claude/skills/tmuxc/COMM-GUIDE.md 를 지금 Read하고 그대로 따를 것. 너의 세션명(me)=$name. 세션간 메시지는 검증 송신 프로토콜 준수."
  else
    guide="[$(tmux display-message -p '#S' 2>/dev/null || printf 'orch')→$name] tmuxc Codex 세션. 통신 표준: ~/.claude/skills/tmuxc/COMM-GUIDE.md 를 참고하되, Codex에는 --remote-control이 없으므로 tmux verified-send/capture-pane 방식으로 보고할 것. 너의 세션명(me)=$name."
  fi
  inject_message "$name" "$guide"
  if [[ -n "$prompt" ]]; then
    sleep 0.8
    inject_message "$name" "$prompt"
  fi

  # [2026-07-16] headroom 프록시 경유 검증 (claude 전용 — 토큰낭비·계정리밋 방어).
  # claude-hr.sh는 fail-open이라 프록시가 살아있을 때 직결 프로세스 = 우회 스폰. 경고만(kill 안 함).
  if [[ "$agent" == "claude" ]]; then
    local hr_proxy="${TMUXC_HR_PROXY_URL:-http://localhost:8790}" pane_pid claude_pid
    if curl -sf -m1 "$hr_proxy/health" >/dev/null 2>&1; then
      pane_pid="$(tmux list-panes -t "$name" -F '#{pane_pid}' 2>/dev/null | head -1)"
      claude_pid="$(pgrep -P "${pane_pid:-0}" 2>/dev/null | head -1 || true)"
      if [[ -n "$claude_pid" ]] && ! ps eww "$claude_pid" 2>/dev/null | tr ' ' '\n' | grep -q "^ANTHROPIC_BASE_URL=$hr_proxy"; then
        printf '⚠️  HEADROOM_BYPASS: %s(pid=%s)가 프록시(%s) 미경유 직결 — claude-hr.sh 경유 재기동 권고\n' "$name" "$claude_pid" "$hr_proxy" >&2
      fi
    fi
  fi

  printf 'tmuxc session created\nsession=%s\nroot=%s\nagent=%s\nrole=%s\nattach=tmux attach -t %q\n' "$name" "$root" "$agent" "$role" "$name"
}

cmd_list() {
  tmux list-sessions -F '#S	#{session_path}	#{session_attached}' 2>/dev/null || return 0
}

cmd_ask() {
  local name="${1:-}"
  local lines="${2:-40}"
  [[ -n "$name" ]] || die "ask requires <name>"
  tmux has-session -t "$name" 2>/dev/null || die "session not found: $name"
  tmux capture-pane -t "$name" -p | tail -n "$lines"
}

cmd_send() {
  local name="${1:-}"
  shift || true
  [[ -n "$name" ]] || die "send requires <name>"
  [[ $# -gt 0 ]] || die "send requires <message>"
  tmux has-session -t "$name" 2>/dev/null || die "session not found: $name"
  inject_message "$name" "$*"
  sleep 1
  if tmux capture-pane -t "$name" -p | tail -80 | grep -qF "$*"; then
    printf 'delivered=%s\n' "$name"
  else
    printf 'sent=%s verification=not-visible-yet\n' "$name"
  fi
}

cmd_clean() {
  local session command
  while IFS=$'\t' read -r session command; do
    if [[ "$command" == "zsh" || "$command" == "bash" || "$command" == "fish" ]]; then
      printf '%s\n' "$session"
    fi
  done < <(tmux list-panes -a -F '#S	#{pane_current_command}' 2>/dev/null || true)
}

# ---------- UC11: tmux 서버 사망 복원 (restore) ----------

restore_scan_py() {
  local self cand
  self="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
  # 정상 설치(심링크)에서는 bin 옆 ../libexec 로 해석된다.
  cand="$(dirname "$self")/../libexec/tmuxc-restore-scan.py"
  # bin 이 심링크가 아닌 파일 복사본으로 놓인 경우(로컬 수동 sync — cp),
  # ../libexec 가 존재하지 않는다. 전역 설치본으로 폴백해 restore 가 깨지지 않게 한다.
  if [[ ! -f "$cand" && -f "$HOME/.tmuxc/current/core/libexec/tmuxc-restore-scan.py" ]]; then
    cand="$HOME/.tmuxc/current/core/libexec/tmuxc-restore-scan.py"
  fi
  printf '%s' "$cand"
}

# 행 배열 (스캐너 TSV와 1:1)
R_AGENT=() R_NAME=() R_CWD=() R_MODEL=() R_ROUTE=() R_SID=() R_TS=() R_STATUS=() R_SUMMARY=()

restore_load_rows() {
  local since="$1" agent_filter="$2" loose="$3"
  local scan_py extra=()
  scan_py="$(restore_scan_py)"
  [[ -f "$scan_py" ]] || die "scan engine not found: $scan_py"
  [[ "$loose" -eq 1 ]] && extra+=(--loose)
  # 구분자 0x1f: 탭은 IFS whitespace라 빈 중간 필드(cwd="")가 collapse되어 필드가 밀림
  local a n c m r s t st sum
  while IFS=$'\x1f' read -r a n c m r s t st sum; do
    [[ -n "$a" ]] || continue
    R_AGENT+=("$a"); R_NAME+=("$n"); R_CWD+=("$c"); R_MODEL+=("$m")
    R_ROUTE+=("$r"); R_SID+=("$s"); R_TS+=("$t"); R_STATUS+=("$st"); R_SUMMARY+=("$sum")
  done < <(python3 "$scan_py" --since "$since" --agent "$agent_filter" "${extra[@]+"${extra[@]}"}")
}

restore_cmd_for() {
  local i="$1" baton="$2"
  local agent="${R_AGENT[$i]}" name="${R_NAME[$i]}" route="${R_ROUTE[$i]}" sid="${R_SID[$i]}"
  if [[ "$agent" == "codex" ]]; then
    printf 'codex resume %s --dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort="high"' "$sid"
    return 0
  fi
  local body
  body="$(resolve_zsh_alias_chain "$route" || true)"
  [[ -n "$body" ]] || return 1
  if [[ "$baton" -eq 1 ]]; then
    printf '%s --name %q --remote-control %q' "$body" "$name" "$name"
  else
    printf '%s --resume %s --name %q --remote-control %q' "$body" "$sid" "$name" "$name"
  fi
}

restore_print_table() {
  local i
  printf '\n복구 후보 (%d개 — 최신순)\n' "${#R_NAME[@]}"
  printf '%-3s %-7s %-24s %-20s %-5s %-7s %s\n' '#' agent 세션명 모델 route 상태 요약
  for i in "${!R_NAME[@]}"; do
    printf '%-3s %-7s %-24s %-20s %-5s %-7s %s\n' \
      "$((i + 1))" "${R_AGENT[$i]}" "${R_NAME[$i]}" "${R_MODEL[$i]}" "${R_ROUTE[$i]}" "${R_STATUS[$i]}" "${R_SUMMARY[$i]}"
    printf '    cwd=%s\n' "${R_CWD[$i]}"
    printf '    cmd=%s\n' "$(restore_cmd_for "$i" 0 || printf '(alias %s 미해석 — 복구 불가)' "${R_ROUTE[$i]}")"
  done
}

restore_expand_select() {
  local spec="$1" i
  case "$spec" in
    all)    for i in "${!R_NAME[@]}"; do printf '%s\n' "$i"; done ;;
    claude|codex)
      for i in "${!R_NAME[@]}"; do [[ "${R_AGENT[$i]}" == "$spec" ]] && printf '%s\n' "$i"; done ;;
    *)
      local tok
      IFS=',' read -ra toks <<< "$spec"
      for tok in "${toks[@]}"; do
        tok="${tok// /}"
        [[ "$tok" =~ ^[0-9]+$ ]] || die "잘못된 선택: '$tok' (숫자, all, claude, codex만 허용)"
        [[ "$tok" -ge 1 && "$tok" -le "${#R_NAME[@]}" ]] || die "선택 범위 밖: $tok (1-${#R_NAME[@]})"
        printf '%s\n' "$((tok - 1))"
      done
      ;;
  esac
}

restore_wait_ready() {
  local name="$1" agent="$2" try pane child
  for try in 1 2 3 4 5 6 7 8; do
    sleep 3
    if [[ "$agent" == "claude" ]]; then
      # resume 세션은 ctx:0%가 아님 — statusline의 ctx: 출현 = 부팅 완료
      tmux capture-pane -t "$name" -p 2>/dev/null | grep -q 'ctx:' && return 0
    else
      pane="$(tmux list-panes -t "$name" -F '#{pane_pid}' 2>/dev/null | head -1)"
      child="$(pgrep -P "${pane:-0}" 2>/dev/null | head -1 || true)"
      [[ -n "$child" ]] && [[ "$try" -ge 3 ]] && return 0
    fi
  done
  return 1
}

restore_one() {
  local i="$1" baton="$2"
  local agent="${R_AGENT[$i]}" name="${R_NAME[$i]}" cwd="${R_CWD[$i]}" sid="${R_SID[$i]}"
  if [[ "${R_STATUS[$i]}" != "ok" ]]; then
    printf '  ⏭  %s: 상태=%s — 스킵\n' "$name" "${R_STATUS[$i]}"
    return 0
  fi
  if tmux has-session -t "$name" 2>/dev/null; then
    printf '  ⏭  %s: 동명 tmux 세션 이미 존재 — 스킵\n' "$name"
    return 0
  fi
  local run_cmd
  run_cmd="$(restore_cmd_for "$i" "$baton" || true)"
  if [[ -z "$run_cmd" ]]; then
    printf '  ❌ %s: alias %s 해석 실패 — 스킵 (zshrc 확인)\n' "$name" "${R_ROUTE[$i]}"
    return 0
  fi
  tmux new-session -d -s "$name" -c "$cwd"
  inject_message "$name" "$run_cmd"
  if restore_wait_ready "$name" "$agent"; then
    if [[ "$agent" == "claude" ]]; then
      if [[ "$baton" -eq 1 ]]; then
        inject_message "$name" "/baton:resume"
        sleep 1
      fi
      inject_message "$name" "[restore→$name] tmux 서버 사망 후 tmuxc restore로 복원된 세션이다. 통신 표준: ~/.claude/skills/tmuxc/COMM-GUIDE.md 를 Read하고 준수. 너의 세션명(me)=$name. 직전 작업 컨텍스트를 확인하고 이어가라."
    fi
    printf '  ✅ %s (%s) 복원 완료 — attach: tmux attach -t %q\n' "$name" "$agent" "$name"
  else
    printf '  ⚠️  %s: 기동 확인 실패(24초) — 수동 확인 필요: tmux attach -t %q\n' "$name" "$name"
  fi
}

cmd_restore() {
  local since=24 agent_filter="all" select_spec="" baton=0 go=0 loose=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since) since="${2:-}"; shift 2 ;;
      --agent) agent_filter="${2:-}"; shift 2 ;;
      --select) select_spec="${2:-}"; shift 2 ;;
      --baton) baton=1; shift ;;
      --loose) loose=1; shift ;;
      --go) go=1; shift ;;
      --help|-h) usage; exit 0 ;;
      *) die "unknown option for restore: $1" ;;
    esac
  done
  case "$agent_filter" in claude|codex|all) ;; *) die "--agent must be claude|codex|all" ;; esac

  if tmux list-sessions >/dev/null 2>&1; then
    printf '⚠️  tmux 서버가 살아있습니다 (세션 %s개). 서버 사망(UC11)이 아니라 디스커넥트(UC8)일 수 있음 — cmux면 tmuxc recover 검토.\n' \
      "$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')"
  fi

  restore_load_rows "$since" "$agent_filter" "$loose"
  if [[ "${#R_NAME[@]}" -eq 0 ]]; then
    printf '복구 후보 없음 (최근 %s시간, agent=%s). --since 를 늘려보세요.\n' "$since" "$agent_filter"
    case "$agent_filter" in
      codex|all)
        printf '  힌트: codex 대화형(cli) 세션은 thread_name 없이 익명으로 기록되는 경우가 있어, 최근 세션이 없으면 --since 168 처럼 늘려서 다시 시도해보세요.\n'
        ;;
    esac
    return 0
  fi
  restore_print_table

  if [[ -z "$select_spec" ]]; then
    if [[ "$go" -eq 1 ]]; then
      die "--go 는 --select 와 함께 사용하세요 (예: --select all --go)"
    fi
    if [[ -t 0 ]]; then
      printf '\n복구할 세션 선택 (예: 1,3,5 / all / claude / codex / q=종료): '
      read -r select_spec
      [[ -n "$select_spec" && "$select_spec" != "q" ]] || { printf '취소됨.\n'; return 0; }
      go=1
    else
      printf '\n(plan 모드 — 실행하려면: tmuxc restore --select all --go)\n'
      return 0
    fi
  fi

  local indices=()
  while IFS= read -r i; do indices+=("$i"); done < <(restore_expand_select "$select_spec")
  [[ "${#indices[@]}" -gt 0 ]] || { printf '선택된 세션 없음.\n'; return 0; }

  if [[ "$go" -ne 1 ]]; then
    printf '\n(plan 모드 — 선택 %d개. 실행하려면 --go 추가)\n' "${#indices[@]}"
    return 0
  fi

  printf '\n▶ %d개 세션 복원 시작\n' "${#indices[@]}"
  local i
  for i in "${indices[@]}"; do
    restore_one "$i" "$baton"
  done
  printf '완료. tmuxc list 로 확인하세요.\n'
}

main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] || { usage; exit 1; }
  shift || true
  case "$cmd" in
    open|wt) cmd_open "$@" ;;
    list) cmd_list ;;
    attach)
      [[ -n "${1:-}" ]] || die "attach requires <name>"
      tmux attach -t "$1"
      ;;
    send) cmd_send "$@" ;;
    ask) cmd_ask "$@" ;;
    model)
      [[ -n "${1:-}" ]] || die "model requires <name>"
      session_live_launch "$1" || die "session not live or model not found: $1"
      ;;
    msg)
      [[ -n "${1:-}" ]] || die "msg requires <name> <message>"
      local name="$1"
      shift
      cmd_send "$name" "$@"
      sleep 2
      cmd_ask "$name" 30
      ;;
    kill)
      [[ -n "${1:-}" ]] || die "kill requires <name>"
      tmux kill-session -t "$1"
      ;;
    clean) cmd_clean ;;
    restore) cmd_restore "$@" ;;
    help|--help|-h) usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
