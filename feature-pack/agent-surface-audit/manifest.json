{
  "name": "agent-surface-audit",
  "version": "0.1.0",
  "description": "Public-safe read-only dry-run inventory for agent skill and hook surfaces.",
  "commands": [
    {
      "name": "agent-surface-audit",
      "path": "core/bin/agent-surface-audit",
      "required_flags": ["--dry-run"]
    }
  ],
  "public_docs": ["README.md", "INSTALL.md"],
  "private_state_exclusions": [
    ".omc",
    ".omo",
    ".omx",
    ".baton",
    ".fable-team",
    ".pytest_cache",
    "__pycache__",
    "caches",
    "log",
    "logs",
    "session",
    "sessions",
    "settings",
    "auth",
    "token",
    "tokens",
    "hooks.json"
  ],
  "safety": {
    "mode": "dry-run-only",
    "writes_live_runtime": false,
    "reads_secret_contents": false
  }
}
