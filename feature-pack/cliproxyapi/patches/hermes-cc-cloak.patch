+def _camelize_tool_name(name: str) -> str:
+    """snake_case → CamelCase for Claude Code tool-name fingerprint cloaking.
+
+    Anthropic classifies OAuth requests as third-party "extra usage" traffic
+    when tool names look like API-style snake_case (``terminal``, ``read_file``)
+    instead of Claude Code's CamelCase tools (``Bash``, ``Read``, ``Edit``).
+    Sending CamelCase names lets OAuth requests meter against the plan instead.
+    Inverse of :func:`_decamelize_tool_name`.
+    """
+    parts = [p for p in name.split("_") if p != ""]
+    if not parts:
+        return name
+    return "".join(p[:1].upper() + p[1:] for p in parts)
+
+
+def _decamelize_tool_name(name: str) -> str:
+    """CamelCase → snake_case (inverse of :func:`_camelize_tool_name`)."""
+    import re
+
+    return re.sub(r"(?<!^)(?=[A-Z])", "_", name).lower()
+
+
+def _use_cc_tool_cloak(base_url: str | None) -> bool:
+    """Whether to CamelCase-cloak tool names (Anthropic CC fingerprint bypass).
+
+    Gated:
+      * ``HERMES_CC_TOOL_CLOAK`` env var forces on/off when set.
+      * Otherwise auto-detect: a *proxied* Anthropic endpoint (headroom,
+        CLIProxyAPI, etc.) — anything that is not direct ``api.anthropic.com``
+        and not an empty base_url. Direct Anthropic keeps the legacy ``mcp_``
+        behavior so existing OAuth round-trips (GH-25255) stay intact.
+    """
+    import os
+
+    env = os.getenv("HERMES_CC_TOOL_CLOAK")
+    if env is not None:
+        return env.strip().lower() in ("1", "true", "yes", "on")
+    normalized = _normalize_base_url_text(base_url).rstrip("/").lower()
+    if not normalized:
+        return False  # no base_url → direct Anthropic API
+    if "api.anthropic.com" in normalized:
+        return False  # direct Anthropic — keep mcp_ prefix behavior
+    return True  # proxied endpoint (headroom / cliproxy / …)
+
+
