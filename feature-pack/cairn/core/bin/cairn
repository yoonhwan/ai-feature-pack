#!/bin/sh
# cairn CLI 진입점 — 설치 시 ~/.cairn/current/bin/cairn 으로 PATH 등록.
# cairn.py는 실행 cwd 프로젝트의 .cairn/ 원장을 대상으로 동작한다.
CAIRN_HOME="${CAIRN_HOME:-$HOME/.cairn/current}"
VENV_PY="$HOME/.cairn/venv/bin/python"
if [ -n "${CAIRN_PYTHON:-}" ]; then PY="$CAIRN_PYTHON"
elif [ -x "$VENV_PY" ]; then PY="$VENV_PY"
else PY="python3"; fi
exec "$PY" "$CAIRN_HOME/cairn.py" "$@"
