{
  "name": "memory-system",
  "version": "1.0.0",
  "description": "OpenClaw 메모리 시스템 + Obsidian 세컨드브레인 + NotebookLM CLI 통합 구조 세팅",
  "os": ["macos"],
  "dependencies": {
