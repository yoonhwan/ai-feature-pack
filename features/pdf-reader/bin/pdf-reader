#!/usr/bin/env bash
set -euo pipefail

usage="pdf-reader <path> [-p <pages>] [-f <format>]
Formats: md, json, txt"

if [[ $# -lt 1 ]]; then
  echo "$usage" >&2
  exit 1
fi
path="$1"
shift || true
pages="all"
format="md"
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--pages)
      pages="$2"; shift 2;;
    -f|--format)
      format="$2"; shift 2;;
    *)
      echo "Unknown option: $1"; echo "$usage"; exit 1;;
  esac
done

cat <<EOF
PDF Reader Skeleton
Path: $path
Pages: ${pages}
Format: ${format}
EOF
exit 0
